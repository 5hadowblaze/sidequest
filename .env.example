# Frontend (Next.js)
# MPP is scaffolded only — skipped by default for hackathon demos.
SKIP_MPP=true
NEXT_PUBLIC_SKIP_MPP=true
MPP_SECRET_KEY=
MPP_RECIPIENT=
MPP_CURRENCY=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
BACKEND_URL=http://localhost:8000

# Backend (Python agent)
GEMINI_API_KEY=
TAVILY_API_KEY=

# Hackathon demo reliability — skip live Tavily/Prometheux and serve seeded events
# USE_DEMO_DATA=true

# Prometheux (required — SDK-only Vadalog filter via prometheux_chain)
# 1. Sign up at https://platform.prometheux.ai
# 2. Copy your API token from account settings
PMTX_TOKEN=

# JarvisPy API base — use api.prometheux.ai (platform host returns HTML, not JSON)
# Format: https://api.prometheux.ai/jarvispy/{org}/{username}
JARVISPY_URL=

# Project namespace for save_concept/run_concept (default — no manual project setup)
PMTX_PROJECT_ID=weekend-planner

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
