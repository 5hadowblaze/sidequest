# Frontend (Next.js) — Sidequest web app. Copy to frontend/.env.local
MPP_SECRET_KEY=
MPP_RECIPIENT=
MPP_CURRENCY=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
BACKEND_URL=http://localhost:8000

# Mirror backend USE_DEMO_DATA for shorter discover loading copy
# NEXT_PUBLIC_USE_DEMO_DATA=true

# Guided Live Demo button (demo branch only; keep false on main)
NEXT_PUBLIC_ENABLE_DEMO=false

# Set true for local dev without wallet payment
SKIP_MPP=true

# Map uses Leaflet + OpenStreetMap (no API key required)

# Firebase (Project Settings → Your apps → Web app config; optional — mock auth if unset)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase App Check — reCAPTCHA Enterprise site key (Firebase Console → App Check)
# Required in production when set; skipped in local dev if unset.
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=
# Optional: fixed debug token for local App Check (register in Firebase Console → App Check → Debug tokens)
# NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=

# MPP wallet keys are SERVER-ONLY (MPP_SECRET_KEY above). Never expose private keys via NEXT_PUBLIC_*.
